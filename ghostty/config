font-family = Maple Mono
font-size = 14
font-family-italic = Maple Mono
theme = Gruvbox Dark Hard
macos-titlebar-style = tabs
cursor-style = underline
shell-integration-features = no-cursor
window-width = 150
window-height = 40
window-padding-x = 10
window-padding-y = 2

# Appearance
background-opacity = 0.95
background-blur = true
adjust-cell-height = 1
scrollbar = never
split-divider-color = #b0b9f9

# Keybindings with Ctrl+a as prefix (like tmux)
# Split navigation (hjkl style)
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right

# Split creation (similar to tmux _ and -)
keybind = ctrl+a>shift+minus=new_split:right
keybind = ctrl+a>minus=new_split:down

# New tab/window (similar to tmux c)
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>n=new_window

# Tab navigation
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>shift+p=next_tab
keybind = ctrl+a>1=goto_tab:1
keybind = ctrl+a>2=goto_tab:2
keybind = ctrl+a>3=goto_tab:3
keybind = ctrl+a>4=goto_tab:4
keybind = ctrl+a>5=goto_tab:5
keybind = ctrl+a>6=goto_tab:6
keybind = ctrl+a>7=goto_tab:7
keybind = ctrl+a>8=goto_tab:8
keybind = ctrl+a>9=goto_tab:9

# Close (similar to tmux x and X)
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>shift+x=close_window

# Split resizing (HJKL style)
keybind = ctrl+a>shift+h=resize_split:left,50
keybind = ctrl+a>shift+j=resize_split:down,50
keybind = ctrl+a>shift+k=resize_split:up,50
keybind = ctrl+a>shift+l=resize_split:right,50

# Zoom split
keybind = ctrl+a>z=toggle_split_zoom

# Send Ctrl+a to terminal when pressed twice (like tmux)
keybind = ctrl+a>ctrl+a=text:\x01

# Config reload
keybind = ctrl+a>shift+r=reload_config
keybind = ctrl+a>shift+e=open_config

# Keep some default Cmd keybindings for convenience
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+n=new_window
keybind = cmd+shift+c=copy_to_clipboard
keybind = cmd+shift+v=paste_from_clipboard
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size

